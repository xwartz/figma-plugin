{
  "name": "design-handoff-bridge",
  "version": "1.0.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xwartz/figma-plugin.git"
  },
  "description": "Design Handoff Bridge helps designers export design tokens and create GitHub handoff issues from Figma selections.",
  "keywords": [
    "figma",
    "plugin",
    "tokens",
    "design tokens",
    "design system",
    "design handoff",
    "github issues"
  ],
  "author": {
    "name": "xwartz",
    "url": "https://github.com/xwartz"
  },
  "scripts": {
    "build:plugin": "node scripts/build-plugin.mjs",
    "build": "pnpm run build:plugin",
    "dev": "node --watch-path=src --watch-path=manifest.json scripts/build-plugin.mjs",
    "release:community": "node scripts/figma-community-release.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:fix:unsafe": "biome check --write --unsafe .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm run check && pnpm run test && pnpm run build"
  },
  "type": "commonjs",
  "dependencies": {
    "decimal.js": "10.6.0",
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@biomejs/biome": "2.5.3",
    "@figma/plugin-typings": "1.130.0",
    "@octokit/core": "7.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "buffer": "6.0.3",
    "clipboard-copy": "4.0.1",
    "conventional-changelog": "8.0.1",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-figma-ui": "github:PavelLaptev/react-figma-ui#4c8d20dbd911c0008fd4d0b20280f14404f186e7",
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  },
  "packageManager": "pnpm@10.33.1"
}
